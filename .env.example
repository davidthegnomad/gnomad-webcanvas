# Optional CI / local signing variables (never commit real secrets)
# Copy to .env and fill in when configuring release signing.

# Tauri updater / bundle signing (see Tauri docs)
# TAURI_SIGNING_PRIVATE_KEY=
# TAURI_SIGNING_PRIVATE_KEY_PASSWORD=

# macOS notarization (GitHub Actions secrets)
# APPLE_CERTIFICATE=
# APPLE_CERTIFICATE_PASSWORD=
# APPLE_SIGNING_IDENTITY=
# APPLE_ID=
# APPLE_PASSWORD=
# APPLE_TEAM_ID=

# Windows code signing (GitHub Actions secrets — tauri-action reads these automatically)
# WINDOWS_CERTIFICATE=
# WINDOWS_CERTIFICATE_PASSWORD=
# Optional local thumbprint for NSIS signing:
# WINDOWS_CERTIFICATE_THUMBPRINT=

# OpenRouter (ORG workspace — not required for gnomad-preview builds)
# OPENROUTER_API_KEY=
