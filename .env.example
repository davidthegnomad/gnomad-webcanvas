# Gnomad Studio Webcanvas — environment variables
# Copy to .env for local overrides (optional; dev works without this file)
#
#   cp .env.example .env
#
# Vite loads VITE_* variables at build time. Restart the dev server after changes.

# ---------------------------------------------------------------------------
# Web build
# ---------------------------------------------------------------------------

# Base path for static assets. Use "/" for local dev and custom domains.
# GitHub Pages deploys to a subpath — CI sets this automatically.
#
# Examples:
#   VITE_BASE_PATH=/                  → http://127.0.0.1:5173/
#   VITE_BASE_PATH=/gnomad-webcanvas/ → https://davidthegnomad.github.io/gnomad-webcanvas/
VITE_BASE_PATH=/

# ---------------------------------------------------------------------------
# Linux desktop dev (optional)
# ---------------------------------------------------------------------------
# On Fedora/Nobara/Wayland, plain `npm run tauri:dev` may crash WebKit.
# Prefer the built-in workaround instead of setting these manually:
#
#   npm run tauri:dev:linux
#
# GDK_BACKEND=x11
# WEBKIT_DISABLE_DMABUF_RENDERER=1

# ---------------------------------------------------------------------------
# Secrets
# ---------------------------------------------------------------------------
# Webcanvas does not require API keys or secrets to run.
# Bug reports use mailto:david@gnomad.studio — no token needed.
