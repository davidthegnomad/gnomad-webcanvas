    "@tauri-apps/plugin-fs": "^2.5.1",
    "@types/file-saver": "^2.0.7",
    "file-saver": "^2.0.5",
    "jszip": "^3.10.1",
    "lz-string": "^1.5.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-resizable-panels": "^4.11.2",
    "tailwindcss": "^4.3.0",
    "zustand": "^5.0.13"
